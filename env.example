

# NOAA NCDC API Token (for historical climate data)
# Get one free at: https://www.ncdc.noaa.gov/cdo-web/token

# NOAA api.weather.gov (no key needed, just identification)
# This is sent as User-Agent header to identify your tool
NWS_USER_AGENT=GridWatch/1.0 (research, your_email@example.com)

# Project settings
GRIDWATCH_ENV=development
LOG_LEVEL=INFO

# Optional: OpenWeatherMap fallback API key (if you want to add it later)
# OPENWEATHER_API_KEY=

# Optional: PostgreSQL connection (for production deployment later)
# DATABASE_URL=postgresql://user:pass@localhost:5432/gridwatch
